# ==============================================================================
# GeoViable — Environment Variables Template (.env.example)
# ==============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL / PostGIS Database
# ──────────────────────────────────────────────────────────────────────────────
# These variables are used by both the PostgreSQL container and the FastAPI backend.

# Database name (used by PostgreSQL container to auto-create on first run)
POSTGRES_DB=geoviable

# Database superuser (used by PostgreSQL container)
POSTGRES_USER=geoviable

# Database password — USE A STRONG PASSWORD IN PRODUCTION
# Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# ──────────────────────────────────────────────────────────────────────────────
# Backend (FastAPI / Uvicorn)
# ──────────────────────────────────────────────────────────────────────────────

# Full SQLAlchemy connection string.
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
# Inside Docker Compose, <host> must be the service name: geoviable-db
DATABASE_URL=postgresql+psycopg2://geoviable:CHANGE_ME_SECURE_PASSWORD@geoviable-db:5432/geoviable

# Runtime environment — use "production" for production, "development" for local
ENVIRONMENT=production

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG in development; INFO in production
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Spatial Analysis Limits (MVP constraints)
# ──────────────────────────────────────────────────────────────────────────────

# Maximum polygon area in square kilometers
MAX_POLYGON_AREA_KM2=100

# Maximum number of vertices allowed in a single polygon
MAX_POLYGON_VERTICES=10000

# Maximum upload size in megabytes (FastAPI payload limit)
MAX_UPLOAD_SIZE_MB=5

# Timeout for PostGIS spatial queries in seconds
QUERY_TIMEOUT_SECONDS=30

# ──────────────────────────────────────────────────────────────────────────────
# CORS (Cross-Origin Resource Sharing)
# ──────────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins.
# Production:  https://geoviable.movilab.es
# Development: http://localhost:3000
# Example: "https://geoviable.movilab.es,http://localhost:3000"
CORS_ORIGINS=https://geoviable.movilab.es
